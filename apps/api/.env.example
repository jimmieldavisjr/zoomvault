# =============================================================================
# ZoomVault API — environment variables
# =============================================================================
# Copy this file to `.env` for local development and fill in real values.
#
# === OUTSIDE-CURSOR OPERATIONS ===
# In production these are set as Railway service variables (Project -> service
# -> Variables), NOT committed to git. `.env` is gitignored. Never paste real
# secrets into chat, logs, screenshots, or committed files.

# PostgreSQL connection string.
# Railway: use the provided DATABASE_URL (or reference ${{ Postgres.DATABASE_URL }}).
DATABASE_URL="postgresql://postgres:RxbzUXWhznebKiIXCQzqDDyaPxhcEKiW@thomas.proxy.rlwy.net:28092/railway"

# Zoom webhook "Secret Token" from the Zoom App -> Feature -> Event Subscriptions.
# Used to verify webhook HMAC signatures and answer the CRC handshake.
ZOOM_WEBHOOK_SECRET_TOKEN= 

# Zoom Server-to-Server OAuth app credentials (reserved for future use, e.g.
# refreshing expiring play URLs). Not required for the basic webhook flow.
ZOOM_CLIENT_ID= 
ZOOM_CLIENT_SECRET= 

# Resend API key (https://resend.com/api-keys) for recording-ready emails.
RESEND_API_KEY= 

# Address recording-ready notifications are sent FROM. Must be on a domain
# verified in Resend (see OPERATIONS.md).
EMAIL_FROM="ZoomVault <notifications@zoomvault.jdtechnologypartners.com>"

# Address that receives the admin "recording ready" notification.
ADMIN_NOTIFICATION_EMAIL=

# Public base URL of the Next.js frontend (used to build watch links).
APP_PUBLIC_URL=http://localhost:3000

# Public base URL of this API.
API_PUBLIC_URL=http://localhost:4000

# Shared secret the admin enters to access admin endpoints/pages.
ADMIN_ACCESS_CODE=144000

# Default lifetime (in days) for generated share links.
DEFAULT_LINK_EXPIRATION_DAYS=14

# Comma-separated list of browser origins allowed to call this API.
CORS_ORIGINS=http://localhost:3000

# Port the API listens on (Railway injects PORT automatically).
PORT=4000
